---
import { Icon } from "astro-icon/components";
---

<h2
  class="flex items-center font-bold text-lg sm:text-xl mb-4 text-gray-800 dark:text-white"
>
  <Icon name="mdi:clock-fast" class="w-5 h-5 mr-2 text-emerald-500" />
  Disponibilidad
</h2>

<div class="space-y-4">
  <div class="flex items-start">
    <div
      class="bg-emerald-100 dark:bg-emerald-900/30 p-1.5 rounded-lg mt-0.5 mr-3"
    >
      <Icon
        name="mdi:check-circle"
        class="w-4 h-4 text-emerald-600 dark:text-emerald-400"
      />
    </div>
    <div>
      <h3 class="text-sm font-medium text-gray-800 dark:text-gray-200">
        Abierto a proyectos
      </h3>
      <p class="text-xs text-gray-600 dark:text-gray-400 mt-1">
        Freelance, tiempo completo o colaboraciones
      </p>
    </div>
  </div>

  <div class="flex items-start">
    <div class="bg-blue-100 dark:bg-blue-900/30 p-1.5 rounded-lg mt-0.5 mr-3">
      <Icon
        name="mdi:clock-outline"
        class="w-4 h-4 text-blue-600 dark:text-blue-400"
      />
    </div>
    <div>
      <h3 class="text-sm font-medium text-gray-800 dark:text-gray-200">
        Tiempo de respuesta
      </h3>
      <p class="text-xs text-gray-600 dark:text-gray-400 mt-1">
        Usualmente respondo en menos de 24 horas
      </p>
    </div>
  </div>

  <div class="flex items-start">
    <div
      class="bg-indigo-100 dark:bg-indigo-900/30 p-1.5 rounded-lg mt-0.5 mr-3"
    >
      <Icon
        name="mdi:map-marker"
        class="w-4 h-4 text-indigo-600 dark:text-indigo-400"
      />
    </div>
    <div>
      <h3 class="text-sm font-medium text-gray-800 dark:text-gray-200">
        Ubicación
      </h3>
      <p class="text-xs text-gray-600 dark:text-gray-400 mt-1">
        Santo Domingo, RD · Remoto disponible
      </p>
    </div>
  </div>
</div>
