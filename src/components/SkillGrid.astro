---
import { Icon } from "astro-icon/components";

// Organized skills matching the Bento section categories
const skills = {
  Mobile: [
    { name: "React Native", icon: "logos:react", featured: true },
    { name: "Expo", icon: "logos:expo-icon", featured: true },
    { name: "TypeScript", icon: "logos:typescript-icon", featured: true },
    { name: "Zustand", icon: "logos/zustand" },
    { name: "TanStack Query", icon: "logos:react-query-icon" },
    { name: "NativeWind", icon: "logos:tailwindcss-icon" },
  ],
  Frontend: [
    { name: "React", icon: "logos:react", featured: true },
    { name: "Next.js", icon: "logos:nextjs-icon", featured: true },
    { name: "Astro", icon: "logos:astro-icon" },
    { name: "TailwindCSS", icon: "logos:tailwindcss-icon", featured: true },
    { name: "Vite", icon: "logos:vitejs" },
    { name: "Framer Motion", icon: "logos:framer" },
  ],
  Backend: [
    { name: "Node.js", icon: "logos:nodejs-icon", featured: true },
    { name: "Express", icon: "simple-icons:express", featured: true },
    { name: "Prisma ORM", icon: "logos:prisma", featured: true },
    { name: "PostgreSQL", icon: "logos:postgresql", featured: true },
    { name: "MySQL", icon: "logos:mysql-icon" },
    { name: "JWT", icon: "logos:jwt-icon" },
    { name: "Socket.io", icon: "logos:socket-io" },
    { name: "API RESTful", icon: "mdi:api" },
  ],
  Infrastructure: [
    { name: "Docker", icon: "logos:docker-icon", featured: true },
    { name: "Redis", icon: "logos:redis", featured: true },
    { name: "Git", icon: "logos:git-icon", featured: true },
    { name: "Postman", icon: "logos:postman-icon" },
    { name: "Vitest", icon: "logos:vitest" },
    { name: "Playwright", icon: "logos:playwright" },
  ],
};

// Category colors for visual distinction
const categoryColors = {
  Mobile: {
    dot: "bg-cyan-500",
    gradient: "from-cyan-500 to-blue-500",
    bg: "from-cyan-50 to-blue-50 dark:from-cyan-950/20 dark:to-blue-950/20",
    border: "border-cyan-200/50 dark:border-cyan-800/30",
  },
  Frontend: {
    dot: "bg-purple-500",
    gradient: "from-purple-500 to-pink-500",
    bg: "from-purple-50 to-pink-50 dark:from-purple-950/20 dark:to-pink-950/20",
    border: "border-purple-200/50 dark:border-purple-800/30",
  },
  Backend: {
    dot: "bg-green-500",
    gradient: "from-green-500 to-emerald-500",
    bg: "from-green-50 to-emerald-50 dark:from-green-950/20 dark:to-emerald-950/20",
    border: "border-green-200/50 dark:border-green-800/30",
  },
  Infrastructure: {
    dot: "bg-blue-500",
    gradient: "from-blue-500 to-indigo-500",
    bg: "from-blue-50 to-indigo-50 dark:from-blue-950/20 dark:to-indigo-950/20",
    border: "border-blue-200/50 dark:border-blue-800/30",
  },
};
---

<section class="skills-section py-16">
  <div class="max-w-6xl mx-auto px-4">
    <!-- Header -->
    <div class="text-center mb-12">
      <h2
        class="skills-section__title inline-flex items-center gap-2 text-sm font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-3"
      >
        <Icon class="w-4 h-4 text-indigo-500" name="mdi:code-tags" />
        Stack Tecnológico
      </h2>
      <p
        class="skills-section__description text-2xl lg:text-3xl font-bold text-gray-900 dark:text-white"
      >
        Tecnologías que domino
      </p>
      <p class="text-gray-600 dark:text-gray-400 mt-2 text-sm max-w-xl mx-auto">
        Herramientas y frameworks que utilizo para crear aplicaciones modernas,
        escalables y de alto rendimiento.
      </p>
    </div>

    <!-- Skills Grid: 2x2 on desktop, stacked on mobile -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 lg:gap-6">
      {
        Object.entries(skills).map(([category, items]) => {
          const colors =
            categoryColors[category as keyof typeof categoryColors];
          return (
            <div class="skills-section__category group">
              <div
                class={`h-full p-5 lg:p-6 rounded-2xl bg-gradient-to-br ${colors.bg} backdrop-blur-sm border ${colors.border} shadow-sm hover:shadow-lg transition-all duration-300`}
              >
                {/* Category Header */}
                <div class="flex items-center gap-2 mb-4">
                  <span
                    class={`w-2 h-2 rounded-full bg-gradient-to-r ${colors.gradient}`}
                  />
                  <h3 class="skills-section__category-title text-lg font-bold text-gray-800 dark:text-gray-100">
                    {category}
                  </h3>
                  <span class="ml-auto text-xs text-gray-500 dark:text-gray-400 bg-white/50 dark:bg-gray-800/50 px-2 py-0.5 rounded-full">
                    {items.length} skills
                  </span>
                </div>

                {/* Skills List */}
                <div class="skills-section__grid grid grid-cols-2 sm:grid-cols-3 gap-2.5">
                  {items.map(({ name, icon, featured }) => (
                    <div
                      class={`skills-section__item group/item relative flex items-center gap-2.5 p-3 rounded-xl backdrop-blur-sm transition-all duration-300 ease-out cursor-default ${
                        featured
                          ? "bg-white/80 dark:bg-gray-800/80 shadow-md border border-white/50 dark:border-gray-600/50 hover:shadow-lg hover:bg-white dark:hover:bg-gray-800"
                          : "bg-white/40 dark:bg-gray-800/40 border border-white/30 dark:border-gray-700/30 hover:bg-white/70 dark:hover:bg-gray-800/60 hover:shadow-md hover:border-white/50 dark:hover:border-gray-600/50"
                      }`}
                    >
                      <div
                        class={`p-1.5 rounded-lg ${featured ? "bg-gradient-to-br from-gray-50 to-gray-100 dark:from-gray-700 dark:to-gray-800" : "bg-white/50 dark:bg-gray-700/50"}`}
                      >
                        <Icon
                          name={icon}
                          class="skills-section__item-icon w-4 h-4 flex-shrink-0"
                        />
                      </div>
                      <span class="skills-section__item-name text-xs font-medium text-gray-700 dark:text-gray-200 truncate">
                        {name}
                      </span>
                      {featured && (
                        <span class="absolute -top-0.5 -right-0.5 w-2 h-2 bg-gradient-to-r from-amber-400 to-orange-400 rounded-full ring-2 ring-white dark:ring-gray-900" />
                      )}
                    </div>
                  ))}
                </div>
              </div>
            </div>
          );
        })
      }
    </div>

    <!-- Bottom indicator -->
    <div class="flex justify-center mt-8">
      <div
        class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-gradient-to-r from-indigo-50 to-purple-50 dark:from-indigo-950/30 dark:to-purple-950/30 border border-indigo-200/50 dark:border-indigo-800/50"
      >
        <span class="flex gap-1">
          <span class="w-1.5 h-1.5 bg-cyan-500 rounded-full"></span>
          <span class="w-1.5 h-1.5 bg-purple-500 rounded-full"></span>
          <span class="w-1.5 h-1.5 bg-green-500 rounded-full"></span>
          <span class="w-1.5 h-1.5 bg-blue-500 rounded-full"></span>
        </span>
        <span class="text-xs font-medium text-gray-600 dark:text-gray-300">
          Full-Stack Development
        </span>
      </div>
    </div>
  </div>
</section>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  const skillsCategories = document.querySelectorAll(
    ".skills-section__category"
  );

  skillsCategories.forEach((category) => {
    const skillsItems = category.querySelectorAll(".skills-section__item");
    const categoryTitle = category.querySelector(
      ".skills-section__category-title"
    );

    // Set initial states - subtle starting position
    gsap.set(categoryTitle, { opacity: 0, y: 10 });
    gsap.set(skillsItems, { opacity: 0, y: 15 });

    ScrollTrigger.create({
      trigger: category,
      start: "top 88%",
      end: "bottom 20%",
      onEnter: () => {
        // Animate category title first with smooth ease
        gsap.to(categoryTitle, {
          opacity: 1,
          y: 0,
          duration: 0.7,
          ease: "power2.out",
        });

        // Then animate skill items with smooth stagger
        gsap.to(skillsItems, {
          opacity: 1,
          y: 0,
          duration: 0.5,
          stagger: {
            amount: 0.4,
            from: "start",
            ease: "none",
          },
          ease: "power2.out",
          delay: 0.1,
        });
      },
      onLeaveBack: () => {
        gsap.to([categoryTitle, ...skillsItems], {
          opacity: 0,
          y: 10,
          duration: 0.3,
          stagger: {
            amount: 0.1,
            from: "end",
          },
          ease: "power2.in",
        });
      },
    });
  });
</script>
